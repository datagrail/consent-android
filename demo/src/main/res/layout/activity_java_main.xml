<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DataGrail Consent SDK - Java Demo"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- Config URL Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Config URL:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingTop="8dp" />

        <EditText
            android:id="@+id/configUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter config URL"
            android:inputType="textUri"
            android:textSize="12sp"
            android:paddingBottom="8dp" />

        <!-- Initialize Button -->
        <Button
            android:id="@+id/initButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initialize SDK"
            android:textAllCaps="false" />

        <!-- Status -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingTop="16dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not initialized"
            android:textSize="12sp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />

        <!-- Banner Buttons -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Banner:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingTop="8dp" />

        <Button
            android:id="@+id/showBannerModalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Modal Banner"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/showBannerFullScreenButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Full Screen Banner"
            android:textAllCaps="false" />

        <!-- Programmatic Actions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Programmatic Actions:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/acceptAllButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Accept All"
                android:textAllCaps="false"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/rejectAllButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reject All"
                android:textAllCaps="false"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Reset Button -->
        <Button
            android:id="@+id/resetButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset SDK"
            android:textAllCaps="false" />

        <!-- Debug Log -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Debug Log:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingTop="16dp" />

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logs will appear here..."
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            android:background="#f5f5f5"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>
